+
+            summarySectionDivider()
+
+            summaryBlockHeader("Trip Summary")
+            summaryValueRow("Route", value: "\(trip.origin) → \(trip.destination)")
+            summaryValueRow(
+                "Scheduled",
+                value: trip.scheduledDate.formatted(.dateTime.month(.abbreviated).day().year().hour().minute())
+            )
